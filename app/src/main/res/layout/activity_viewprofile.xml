<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ViewProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AFCBFF">

    <!-- Title -->
    <TextView
        android:id="@+id/profileTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Profile"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- White Profile Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/profileCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="36dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#EAF2FF"
        app:layout_constraintTop_toBottomOf="@id/profileTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <!-- Username Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <ImageView
                android:id="@+id/iconUser"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_profile"
                app:tint="#212121"
                android:contentDescription="User Icon" />

            <TextView
                android:id="@+id/editUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:hint="Email"
                android:textColor="#212121"
                android:textSize="22sp"
                android:background="@android:color/transparent" />
        </LinearLayout>

            <!-- Password Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:id="@+id/iconPassword"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_password"
                    app:tint="#212121"
                    android:contentDescription="Password Icon" />

                <TextView
                    android:id="@+id/textPassword"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:hint="Password"
                    android:textColor="#212121"
                    android:textSize="22sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Height Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:id="@+id/iconHeight"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_height"
                    app:tint="#212121"
                    android:contentDescription="Height Icon" />

                <EditText
                    android:id="@+id/editHeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:hint="Height"
                    android:textColor="#212121"
                    android:textSize="22sp"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- Weight Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:id="@+id/iconWeight"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_weight"
                    app:tint="#212121"
                    android:contentDescription="Weight Icon" />

                <EditText
                    android:id="@+id/editWeight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:hint="Weight"
                    android:textColor="#212121"
                    android:textSize="22sp"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- Age Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <ImageView
                    android:id="@+id/iconAge"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_age"
                    app:tint="#212121"
                    android:contentDescription="Age Icon" />

                <EditText
                    android:id="@+id/editAge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:hint="Age"
                    android:textColor="#212121"
                    android:textSize="22sp"
                    android:background="@android:color/transparent" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Save Button-->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Save Profile"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="#212121"
        android:backgroundTint="#6FAF63"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:cornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/profileCard"
        app:layout_constraintBottom_toTopOf="@id/btnLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logout Button -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="Log Out"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="26sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF0000"
        android:layout_marginTop="16dp"
        app:cornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnSave"
        app:layout_constraintBottom_toTopOf="@id/bottomBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Tab -->
    <View
        android:id="@+id/bottomBarBackground"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/bottom_nav_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Safe area inside the blue bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavContent"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/bottomBarBackground"
        app:layout_constraintBottom_toBottomOf="@id/bottomBarBackground"
        app:layout_constraintStart_toStartOf="@id/bottomBarBackground"
        app:layout_constraintEnd_toEndOf="@id/bottomBarBackground">

        <!-- ChatBot Nav -->
        <ImageButton
            android:id="@+id/navLeft"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_chat"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="Chat Tab"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/navViewWorkout"
            app:layout_constraintHorizontal_chainStyle="spread_inside" />

        <!-- View Workout Nav -->
        <ImageButton
            android:id="@+id/navViewWorkout"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_workout_list"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="View Workouts Tab"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navLeft"
            app:layout_constraintEnd_toStartOf="@id/navCenter" />

        <!-- Create Workout Nav -->
        <ImageButton
            android:id="@+id/navCenter"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_add"
            android:background="@drawable/center_nav_circle"
            android:scaleType="centerInside"
            android:padding="1dp"
            android:contentDescription="Create Workout Tab"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navViewWorkout"
            app:layout_constraintEnd_toStartOf="@id/navRight" />

        <!-- View Profile Nav -->
        <ImageButton
            android:id="@+id/navRight"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_profile"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="Profile Tab"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navCenter"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>