<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ActivityLogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#AFCBFF"
    android:padding="24dp">

    <!--Welcome to Liftly text-->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome To Liftly"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:gravity="center"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="70dp"/>

    <!--Enter Email Input Box-->
    <EditText
        android:id="@+id/etEmail"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:hint="Enter Email"
        android:textSize="20sp"
        android:padding="12dp"
        android:backgroundTint="#212121"
        android:inputType="textEmailAddress" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="45dp"/>


    <!--Enter Password Input Box-->
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:hint="Enter Password"
        android:textSize="20sp"
        android:padding="12dp"
        android:backgroundTint="#212121"
        android:inputType="textPassword" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="5dp"/>

    <!--Forgot Password-->
    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot Password"
        android:textSize="22sp"
        android:textColor="#212121"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"/>

    <!--Create New Account-->
    <TextView
        android:id="@+id/tvCreateAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create New Account"
        android:textSize="22sp"
        android:textColor="#212121"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:clickable="true"
        android:focusable="true"/>

    <Space
        android:layout_width="match_parent"
        android:layout_height="5dp"/>

    <!--Login Error Message(hidden at first)-->
    <TextView
        android:id="@+id/loginError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Invalid Email or Password"
        android:textColor="#D32F2F"
        android:textSize="20sp"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"/>

    
    <Space
        android:layout_width="match_parent"
        android:layout_height="20dp"/>

    <!--Login Button-->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="LOGIN"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:backgroundTint="#6FAF63"
        android:layout_marginBottom="40dp"/>
</LinearLayout>