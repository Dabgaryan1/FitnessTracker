<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AFCBFF">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineThreeQuarter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.75" />

    <!--Back Button -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="12dp"
        android:background="@android:color/transparent"
        android:contentDescription="Back"
        android:src="@drawable/back_arrow"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Workout"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Input exercise name -->
    <EditText
        android:id="@+id/etExerciseName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:hint="Name of Exercise"
        android:backgroundTint="#5E7CCF"
        app:layout_constraintTop_toBottomOf="@id/backButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnAddExercise" />

    <!-- Input exercise type -->
    <EditText
        android:id="@+id/etExerciseType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Type: Barbell, Dumbbell, Machine"
        android:backgroundTint="#5E7CCF"
        app:layout_constraintTop_toBottomOf="@id/etExerciseName"
        app:layout_constraintStart_toStartOf="@id/etExerciseName"
        app:layout_constraintEnd_toEndOf="@id/etExerciseName" />

    <!-- Input muscle group -->
    <EditText
        android:id="@+id/etMuscleGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="Muscle Group: Chest, Back, Legs"
        android:backgroundTint="#5E7CCF"
        app:layout_constraintTop_toBottomOf="@id/etExerciseType"
        app:layout_constraintStart_toStartOf="@id/etExerciseName"
        app:layout_constraintEnd_toEndOf="@id/etExerciseName" />

    <!-- Add button to recyclerview -->
    <Button
        android:id="@+id/btnAddExercise"
        android:layout_width="80dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:text="Add"
        android:textColor="#AFCBFF"
        android:backgroundTint="#212121"
        app:layout_constraintTop_toTopOf="@id/etMuscleGroup"
        app:layout_constraintBottom_toBottomOf="@id/etMuscleGroup"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RecyclerView list of exercises -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerExercises"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/etMuscleGroup"
        app:layout_constraintBottom_toTopOf="@id/btnSaveWorkout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/activity_itemexercise" />

    <!-- Save Workout Button -->
    <Button
        android:id="@+id/btnSaveWorkout"
        android:layout_width="160dp"
        android:layout_height="60dp"
        android:text="Save Workout"
        android:textStyle="bold"
        android:textColor="#212121"
        android:textSize="7pt"
        android:backgroundTint="#6FAF63"
        app:layout_constraintTop_toTopOf="@id/guidelineThreeQuarter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Tab -->
    <View
        android:id="@+id/bottomBarBackground"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/bottom_nav_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Safe area inside the blue bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavContent"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/bottomBarBackground"
        app:layout_constraintBottom_toBottomOf="@id/bottomBarBackground"
        app:layout_constraintStart_toStartOf="@id/bottomBarBackground"
        app:layout_constraintEnd_toEndOf="@id/bottomBarBackground">

        <!-- ChatBot Nav -->
        <ImageButton
            android:id="@+id/navLeft"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_chat"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="Chat Tab"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/navViewWorkout"
            app:layout_constraintHorizontal_chainStyle="spread_inside" />

        <!-- View Workout Nav -->
        <ImageButton
            android:id="@+id/navViewWorkout"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_workout_list"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="View Workouts Tab"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navLeft"
            app:layout_constraintEnd_toStartOf="@id/navCenter" />

        <!-- Create Workout Nav -->
        <ImageButton
            android:id="@+id/navCenter"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_add"
            android:background="@drawable/center_nav_circle"
            android:scaleType="centerInside"
            android:padding="1dp"
            android:contentDescription="Create Workout Tab"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navViewWorkout"
            app:layout_constraintEnd_toStartOf="@id/navRight" />

        <!-- View Profile Nav -->
        <ImageButton
            android:id="@+id/navRight"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_profile"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="Profile Tab"
            android:layout_marginBottom="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navCenter"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>