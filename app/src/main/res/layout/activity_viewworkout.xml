<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ViewWorkout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AFCBFF">

    <TextView
        android:id="@+id/viewWorkoutsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="View Workouts"
        android:textSize="42sp"
        android:textStyle="bold"
        android:textColor="#212121"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmptyWorkouts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No saved workouts yet"
        android:textColor="#212121"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/viewWorkoutsTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/workoutRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/viewWorkoutsTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomBarBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/activity_itemsavedworkout" />

    <View
        android:id="@+id/bottomBarBackground"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:background="@drawable/bottom_nav_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNavContent"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/bottomBarBackground"
        app:layout_constraintBottom_toBottomOf="@id/bottomBarBackground"
        app:layout_constraintStart_toStartOf="@id/bottomBarBackground"
        app:layout_constraintEnd_toEndOf="@id/bottomBarBackground">

        <ImageButton
            android:id="@+id/navLeft"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/ic_chat"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="Chat Tab"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/navViewWorkout"
            app:layout_constraintHorizontal_chainStyle="spread_inside" />

        <ImageButton
            android:id="@+id/navViewWorkout"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/ic_workout_list"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="View Workouts Tab"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navLeft"
            app:layout_constraintEnd_toStartOf="@id/navCenter" />

        <ImageButton
            android:id="@+id/navCenter"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_add"
            android:background="@drawable/center_nav_circle"
            android:scaleType="centerInside"
            android:padding="1dp"
            android:contentDescription="Create Workout Tab"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navViewWorkout"
            app:layout_constraintEnd_toStartOf="@id/navRight" />

        <ImageButton
            android:id="@+id/navRight"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/ic_profile"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:contentDescription="Profile Tab"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navCenter"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>